{
  "schema": {
    "description": "Template for player data structure following the consolidated dev guide",
    "player": {
      "id": "string - UUID-based unique identifier (e.g., p_12a3b4c5-d6e7-f8g9-h0i1-j2k3l4m5n6o7)",
      "name": "string - Display name",
      "fullName": "string - Full legal name (for name tweaking failsafe)",
      "age": "number - Current age in years",
      "nationality": "string - ISO country code (e.g., IND, AUS, ENG)",
      "role": "string - batsman | bowler | all-rounder | wicket-keeper",
      "battingHand": "string - right | left",
      "bowlingHand": "string - right | left | null (for non-bowlers)",
      "bowlingType": "string - pace | spin | null",
      "bowlingStyle": "string - Full bowling style description (e.g., Right-arm fast-medium, Slow left-arm orthodox) | null",
      "bowlingStyleAbbrev": "string - Abbreviated bowling style (e.g., RFM, SLA, LBG) | null",
      "teams": "array - Array of team IDs player has been part of (historical)",
      "currentTeam": "string - Current team ID or null if unassigned",
      "attributes": {
        "batting": {
          "technique": "number 1-20",
          "timing": "number 1-20",
          "footwork": "number 1-20",
          "placement": "number 1-20",
          "range360": "number 1-20",
          "defensiveShots": "number 1-20",
          "neutralShots": "number 1-20",
          "attackingShots": "number 1-20",
          "vsPace": "number 1-20",
          "vsSpin": "number 1-20",
          "creativity": "number 1-20"
        },
        "bowling": {
          "accuracy": "number 1-20",
          "bowlingSpeed": "number 1-20",
          "swing": "number 1-20",
          "turn": "number 1-20",
          "flight": "number 1-20",
          "variations": "number 1-20",
          "intelligence": "number 1-20",
          "defensiveBowling": "number 1-20",
          "neutralBowling": "number 1-20",
          "attackingBowling": "number 1-20"
        },
        "physical": {
          "strength": "number 1-20",
          "speed": "number 1-20",
          "agility": "number 1-20",
          "maxFitness": "number 1-20",
          "endurance": "number 1-20",
          "stamina": "number 1-20"
        },
        "fielding": {
          "catching": "number 1-20",
          "reflexes": "number 1-20",
          "groundFielding": "number 1-20",
          "throwPower": "number 1-20",
          "throwAccuracy": "number 1-20",
          "keeping": "number 1-20",
          "collecting": "number 1-20",
          "stumping": "number 1-20"
        },
        "mental": {
          "concentration": "number 1-20",
          "temperament": "number 1-20",
          "aggression": "number 1-20",
          "judgement": "number 1-20",
          "leadership": "number 1-20"
        },
        "overall": {
          "batting_overall": "number 0-100",
          "bowling_overall": "number 0-100"
        }
      },
      "careerStats": {
        "matches": "number",
        "innings": "number",
        "runs": "number",
        "wickets": "number",
        "catches": "number",
        "stumpings": "number"
      },
      "seasonStats": {
        "matches": "number",
        "innings": "number",
        "runs": "number",
        "wickets": "number",
        "catches": "number",
        "stumpings": "number"
      },
      "condition": {
        "form": "number 0-100",
        "fitness": "number 0-100",
        "fatigue": "number 0-100",
        "morale": "number 0-100",
        "injury": "string - null | minor | moderate | severe",
        "confidence": "number 0-100",
        "energy": "number 0-100",
        "injuryDuration": "number | null"
      },
      "contract": {
        "salary": "number",
        "duration": "number",
        "retentionStatus": "string"
      },
      "rating": "number",
      "playstyleRatings": {
        "description": "All playstyle ratings calculated from player attributes (0-100 scale)",
        "batting": {
          "Opener - Slogger": "number 0-100",
          "Opener - Balanced": "number 0-100",
          "Opener - Anchor": "number 0-100",
          "Top Order - Slogger": "number 0-100",
          "Top Order - Balanced": "number 0-100",
          "Top Order - Anchor": "number 0-100",
          "Middle Order - Slogger": "number 0-100",
          "Middle Order - Balanced": "number 0-100",
          "Middle Order - Anchor": "number 0-100",
          "Lower Order - Slogger": "number 0-100",
          "Lower Order - Balanced": "number 0-100",
          "Lower Order - Anchor": "number 0-100",
          "Finisher": "number 0-100",
          "Runner": "number 0-100",
          "Pinch-Hitter": "number 0-100",
          "Wall": "number 0-100"
        },
        "bowling": {
          "description": "Bowling playstyles based on bowlingType (pace or spin)",
          "Swing Bowler": "number 0-100 (pace)",
          "Hit-the-Deck Seamer": "number 0-100 (pace)",
          "Short-Ball Specialist": "number 0-100 (pace)",
          "Death Specialist": "number 0-100 (pace)",
          "Classical Spinner": "number 0-100 (spin)",
          "Flat Spinner": "number 0-100 (spin)",
          "Mystery Spinner": "number 0-100 (spin)",
          "Containment Spinner": "number 0-100 (spin)"
        }
      },
      "topPlaystyles": {
        "description": "Top 3 playstyles for each category with ratings",
        "batting": [
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          },
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          },
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          }
        ],
        "bowling": [
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          },
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          },
          {
            "name": "string - Playstyle name",
            "rating": "number 0-100"
          }
        ]
      },
      "primaryPlaystyle": {
        "description": "Player's primary (highest rated) playstyle for their role",
        "batting": "string - Name of primary batting playstyle | null",
        "bowling": "string - Name of primary bowling playstyle | null"
      },
      "tactics": {
        "bowlingStylePreferences": {
          "Swing Bowler": "number 1-8",
          "Hit-the-Deck Seamer": "number 1-8",
          "Short-Ball Specialist": "number 1-8",
          "Death Specialist": "number 1-8",
          "Classical Spinner": "number 1-8",
          "Flat Spinner": "number 1-8",
          "Mystery Spinner": "number 1-8",
          "Containment Spinner": "number 1-8"
        },
        "defaultBattingTier": "string - Build | Rotate | Cruise | Attack | Rampage",
        "defaultBowlingPlans": {
          "lineLength": "string",
          "variation": "string"
        }
      }
    }
  }
}
{
  "version": "1.0.0",
  "description": "Playstyle-based attribute modifiers applied during match simulation",
  "lastUpdated": "2025-01-10",
  "notes": [
    "All modifier values, conditions, and formulas are editable",
    "Modifiers apply multiplicatively: modifiedAttribute = attribute * (1 + PlaystyleRating * scalingFactor)",
    "PlaystyleRating is on 0-100 scale",
    "Conditions use match context fields: phase, over, wicketsInHand, currentRunRate, requiredRunRate, etc.",
    "Multiple modifiers for same playstyle can be active simultaneously"
  ],
  "conditionOperators": {
    "==": "Equal to",
    "!=": "Not equal to",
    ">": "Greater than",
    "<": "Less than",
    ">=": "Greater than or equal",
    "<=": "Less than or equal"
  },

{
  "description": "Transfer system configuration - player trading rules and windows",

  "transferWindows": {
    "preAuction": {
      "name": "Pre-Auction Transfer Window",
      "description": "Brief window before season auction for early moves",
      "duration": 7,
      "timing": "before_auction",
      "maxTransfersPerTeam": 3,
      "enabled": true
    },
    "offSeason": {
      "name": "Off-Season Transfer Window",
      "description": "Extended transfer window during off-season (weeks 22-26)",
      "startAfterMatchWeek": 22,
      "duration": 35,
      "timing": "off_season",
      "maxTransfersPerTeam": 10,
      "enabled": true
    },
    "emergency": {
      "name": "Emergency Transfer",
      "description": "Allowed for injured/unavailable players (if implemented)",
      "maxTransfersPerTeam": 2,
      "enabled": false
    }
  },

  "transferRules": {
    "squadSizeMin": 15,
    "squadSizeMax": 25,

    "minimumListingPrice": 50000,

    "bidMinIncrement": 10000,

    "roleProtection": {
      "minimumBatsmen": 7,
      "minimumBowlers": 6,
      "minimumAllRounders": 2,
      "minimumKeepers": 2
    }
  },

  "listingDuration": {
    "default": 7,
    "maximum": 14
  },

  "aiBuyingBehavior": {
    "reserveAfterBid": 100000,
    "bidFractionMin": 0.10,
    "bidFractionMax": 0.70,
    "dailyBidProbability": 0.50
  },

  "aiListingCriteria": {
    "compositionSurplus": {
      "enabled": true
    },
    "deadCapital": {
      "enabled": true,
      "priceMatchSlabs": [
        { "minPrice": 1000000, "minMatches": 10 },
        { "minPrice": 500000, "minMatches": 5 },
        { "minPrice": 200000, "minMatches": 1 }
      ],
      "minimumTeamMatches": 5
    },
    "vfmEngine": {
      "enabled": true,
      "vfmThreshold": 0.7,
      "minimumMatches": 3
    },
    "listingPrice": {
      "safetyFloorPercent": 0.5
    },
    "maxListingsPerCycle": 5,
    "minimumEffectiveSquad": 18
  },

  "releaseRules": {
    "preWindowSquadThreshold": 23,
    "preWindowMaxReleases": 2,
    "unplayedMinPrice": 200000,
    "releaseRecoupRate": 0.30,
    "autoReleaseOnExpiry": {
      "compositionSurplus": { "requireStillSurplus": true, "requireNotTop11IPM": true },
      "deadCapital": { "requireZeroMatches": true, "minPrice": 200000 },
      "vfmFailure": { "maxVfmScore": 0.30 }
    }
  },

  "notifications": {
    "newListing": true,
    "offerReceived": true,
    "transferCompleted": true
  }
}

flowchart TD
    START([Ball Simulation Start]) --> SETUP[Calculate Pre-Ball Setup<br/>• Striker/Bowler In-Match Conditions<br/>• Tactical Instructions<br/>• Field Setting]
    
    SETUP --> CONTACT{Contact Quality}
    
    %% MISSED BRANCH
    CONTACT --> MISSED[MISSED]
    MISSED --> MISS_TYPE{Miss Type}
    MISS_TYPE --> BEATEN[Beaten - DOT BALL]
    MISS_TYPE --> WICKET[Wicket]
    WICKET --> BOWLED[BOWLED]
    WICKET --> LBW[LBW]
    WICKET --> HIT_WICKET[HIT WICKET]
    
    %% EDGED BRANCH
    CONTACT --> EDGED[EDGED]
    EDGED --> EDGE_DIRECTION{Edge Direction}
    EDGE_DIRECTION --> TO_KEEPER[To Keeper]
    EDGE_DIRECTION --> TO_SLIP[To Slip]
    EDGE_DIRECTION --> EDGE_RUNS[Neither - Edge Runs]
    
    TO_KEEPER --> KEEPER_ACTION{Keeper Action}
    KEEPER_ACTION --> CAUGHT_KEEPER[CAUGHT - Keeper]
    KEEPER_ACTION --> KEEPER_FUMBLE[Keeper Misfield - Runs]
    
    TO_SLIP --> SLIP_ACTION{Slip Action}
    SLIP_ACTION --> CAUGHT_SLIP[CAUGHT - Slip]
    SLIP_ACTION --> SLIP_DROP[Slip Drop - Runs]
    
    %% MIDDLED BRANCH
    CONTACT --> MIDDLED[MIDDLED]
    MIDDLED --> SHOT_TYPE{Shot Type}
    SHOT_TYPE --> MISHIT[Mishit]
    SHOT_TYPE --> GOOD_HIT[Good Hit]
    SHOT_TYPE --> SMASHED[Smashed]
    
    %% MISHIT TRAJECTORY
    MISHIT --> MISHIT_TRAJ{Trajectory}
    MISHIT_TRAJ --> MISHIT_GROUND[Grounded]
    MISHIT_TRAJ --> MISHIT_AERIAL[Aerial]
    
    %% GOOD HIT TRAJECTORY
    GOOD_HIT --> GOOD_TRAJ{Trajectory}
    GOOD_TRAJ --> GOOD_GROUND[Grounded]
    GOOD_TRAJ --> GOOD_AERIAL[Aerial]
    
    %% SMASHED TRAJECTORY
    SMASHED --> SMASHED_TRAJ{Trajectory}
    SMASHED_TRAJ --> SMASHED_GROUND[Grounded]
    SMASHED_TRAJ --> SMASHED_AERIAL[Aerial]
    
    %% MISHIT GROUNDED OUTCOMES
    MISHIT_GROUND --> MISHIT_G_GAP{Gap Analysis}
    MISHIT_G_GAP --> MISHIT_G_IN_GAP[In the Gap]
    MISHIT_G_GAP --> MISHIT_G_FIELDER[Straight to Fielder]
    MISHIT_G_GAP --> MISHIT_G_CHANCE[Fielding Chance]
    
    MISHIT_G_IN_GAP --> MISHIT_G_RUNS[1-2 Runs]
    
    MISHIT_G_FIELDER --> MISHIT_GATHER{Gather Quality}
    MISHIT_GATHER --> MISHIT_CLEAN[Clean Gather - DOT]
    MISHIT_GATHER --> MISHIT_MISFIELD_G[Misfield - Runs]
    
    MISHIT_G_CHANCE --> MISHIT_FIELD{Fielding Action}
    MISHIT_FIELD --> MISHIT_STOP[Clean Stop]
    MISHIT_FIELD --> MISHIT_MISFIELD_C[Misfield - Extra Runs]
    
    MISHIT_STOP --> MISHIT_THROW{Throw}
    MISHIT_THROW --> MISHIT_ON_TARGET[On Target]
    MISHIT_THROW --> MISHIT_MISS_THROW[Miss - Safe Run]
    MISHIT_ON_TARGET --> MISHIT_RUNOUT_CHECK{Run Out Check}
    MISHIT_RUNOUT_CHECK --> MISHIT_RUNOUT[RUN OUT]
    MISHIT_RUNOUT_CHECK --> MISHIT_SAFE[Safe - 1 Run]
    
    %% MISHIT AERIAL OUTCOMES
    MISHIT_AERIAL --> MISHIT_A_GAP{Gap Analysis}
    MISHIT_A_GAP --> MISHIT_A_IN_GAP[In the Gap]
    MISHIT_A_GAP --> MISHIT_A_FIELDER[Straight to Fielder]
    MISHIT_A_GAP --> MISHIT_A_CHANCE[Fielding Chance]
    
    MISHIT_A_IN_GAP --> MISHIT_A_RUNS[2-3 Runs]
    
    MISHIT_A_FIELDER --> MISHIT_CATCH_EASY{Easy Catch}
    MISHIT_CATCH_EASY --> MISHIT_CAUGHT_EASY[CAUGHT]
    MISHIT_CATCH_EASY --> MISHIT_DROP_EASY[Drop - 1 Run]
    
    MISHIT_A_CHANCE --> MISHIT_CATCH_HARD{Difficult Catch}
    MISHIT_CATCH_HARD --> MISHIT_CAUGHT_HARD[CAUGHT]
    MISHIT_CATCH_HARD --> MISHIT_STOP_A[Stop - 2 Runs]
    MISHIT_CATCH_HARD --> MISHIT_DROP_HARD[Drop - 2 Runs]
    
    %% GOOD HIT GROUNDED OUTCOMES
    GOOD_GROUND --> GOOD_G_GAP{Gap Analysis}
    GOOD_G_GAP --> GOOD_G_IN_GAP[In the Gap]
    GOOD_G_GAP --> GOOD_G_FIELDER[Straight to Fielder]
    GOOD_G_GAP --> GOOD_G_CHANCE[Fielding Chance]
    
    GOOD_G_IN_GAP --> GOOD_BOUNDARY_CHECK{Boundary Check}
    GOOD_BOUNDARY_CHECK --> GOOD_FOUR_G[FOUR - Grounded]
    GOOD_BOUNDARY_CHECK --> GOOD_G_RUNS[2-3 Runs]
    
    GOOD_G_FIELDER --> GOOD_GATHER{Gather Quality}
    GOOD_GATHER --> GOOD_CLEAN[Clean Gather - DOT]
    GOOD_GATHER --> GOOD_MISFIELD_G[Misfield - Runs]
    
    GOOD_G_CHANCE --> GOOD_FIELD{Fielding Action}
    GOOD_FIELD --> GOOD_STOP[Clean Stop]
    GOOD_FIELD --> GOOD_MISFIELD_C[Misfield - Extra Runs]
    
    GOOD_STOP --> GOOD_THROW{Throw}
    GOOD_THROW --> GOOD_ON_TARGET[On Target]
    GOOD_THROW --> GOOD_MISS_THROW[Miss - Safe Runs]
    GOOD_ON_TARGET --> GOOD_RUNOUT_CHECK{Run Out Check}
    GOOD_RUNOUT_CHECK --> GOOD_RUNOUT[RUN OUT]
    GOOD_RUNOUT_CHECK --> GOOD_SAFE[Safe - Runs]
    
    %% GOOD HIT AERIAL OUTCOMES
    GOOD_AERIAL --> GOOD_A_GAP{Gap Analysis}
    GOOD_A_GAP --> GOOD_A_IN_GAP[In the Gap - FOUR]
    GOOD_A_GAP --> GOOD_A_FIELDER[Straight to Fielder]
    GOOD_A_GAP --> GOOD_A_CHANCE[Fielding Chance]
    
    GOOD_A_FIELDER --> GOOD_CATCH_EASY{Easy Catch}
    GOOD_CATCH_EASY --> GOOD_CAUGHT_EASY[CAUGHT]
    GOOD_CATCH_EASY --> GOOD_DROP_EASY[Drop - 2 Runs]
    
    GOOD_A_CHANCE --> GOOD_CATCH_HARD{Fielding Action}
    GOOD_CATCH_HARD --> GOOD_CAUGHT_HARD[CAUGHT]
    GOOD_CATCH_HARD --> GOOD_STOP_A[Stop - 2 Runs]
    GOOD_CATCH_HARD --> GOOD_DROP_HARD[Drop - FOUR]
    
    %% SMASHED GROUNDED OUTCOMES
    SMASHED_GROUND --> SMASHED_G_GAP{Gap Analysis}
    SMASHED_G_GAP --> SMASHED_G_IN_GAP[In the Gap - FOUR]
    SMASHED_G_GAP --> SMASHED_G_FIELDER[Straight to Fielder]
    SMASHED_G_GAP --> SMASHED_G_CHANCE[Fielding Chance]
    
    SMASHED_G_FIELDER --> SMASHED_GATHER{Gather Quality}
    SMASHED_GATHER --> SMASHED_CLEAN[Clean Gather - DOT]
    SMASHED_GATHER --> SMASHED_MISFIELD_G[Misfield - FOUR]
    
    SMASHED_G_CHANCE --> SMASHED_FIELD{Fielding Action}
    SMASHED_FIELD --> SMASHED_STOP[Clean Stop]
    SMASHED_FIELD --> SMASHED_MISFIELD_C[Misfield - FOUR]
    
    SMASHED_STOP --> SMASHED_THROW{Throw}
    SMASHED_THROW --> SMASHED_ON_TARGET[On Target]
    SMASHED_THROW --> SMASHED_MISS_THROW[Miss - Safe Runs]
    SMASHED_ON_TARGET --> SMASHED_RUNOUT_CHECK{Run Out Check}
    SMASHED_RUNOUT_CHECK --> SMASHED_RUNOUT[RUN OUT]
    SMASHED_RUNOUT_CHECK --> SMASHED_SAFE[Safe - Runs]
    
    %% SMASHED AERIAL OUTCOMES
    SMASHED_AERIAL --> SMASHED_A_GAP{Gap Analysis}
    SMASHED_A_GAP --> SMASHED_A_IN_GAP[In the Gap - SIX]
    SMASHED_A_GAP --> SMASHED_A_FIELDER[Straight to Fielder]
    SMASHED_A_GAP --> SMASHED_A_CHANCE[Fielding Chance]
    
    SMASHED_A_FIELDER --> SMASHED_CATCH_EASY{Easy Catch}
    SMASHED_CATCH_EASY --> SMASHED_CAUGHT_EASY[CAUGHT]
    SMASHED_CATCH_EASY --> SMASHED_DROP_EASY[Drop - 4 Runs]
    
    SMASHED_A_CHANCE --> SMASHED_CATCH_HARD{Fielding Action}
    SMASHED_CATCH_HARD --> SMASHED_CAUGHT_HARD[CAUGHT]
    SMASHED_CATCH_HARD --> SMASHED_STOP_A[Stop - 4 Runs]
    SMASHED_CATCH_HARD --> SMASHED_DROP_HARD[Drop - SIX]
    
    %% ALL OUTCOMES FLOW TO POST PROCESSING
    BEATEN --> POST_BALL[Post-Ball Processing<br/>• Update Match State<br/>• Update Player Conditions<br/>• Generate Commentary<br/>• Check Match Status]
    BOWLED --> POST_BALL
    LBW --> POST_BALL
    HIT_WICKET --> POST_BALL
    CAUGHT_KEEPER --> POST_BALL
    KEEPER_FUMBLE --> POST_BALL
    CAUGHT_SLIP --> POST_BALL
    SLIP_DROP --> POST_BALL
    EDGE_RUNS --> POST_BALL
    MISHIT_G_RUNS --> POST_BALL
    MISHIT_CLEAN --> POST_BALL
    MISHIT_MISFIELD_G --> POST_BALL
    MISHIT_MISFIELD_C --> POST_BALL
    MISHIT_MISS_THROW --> POST_BALL
    MISHIT_RUNOUT --> POST_BALL
    MISHIT_SAFE --> POST_BALL
    MISHIT_A_RUNS --> POST_BALL
    MISHIT_CAUGHT_EASY --> POST_BALL
    MISHIT_DROP_EASY --> POST_BALL
    MISHIT_CAUGHT_HARD --> POST_BALL
    MISHIT_STOP_A --> POST_BALL
    MISHIT_DROP_HARD --> POST_BALL
    GOOD_FOUR_G --> POST_BALL
    GOOD_G_RUNS --> POST_BALL
    GOOD_CLEAN --> POST_BALL
    GOOD_MISFIELD_G --> POST_BALL
    GOOD_MISFIELD_C --> POST_BALL
    GOOD_MISS_THROW --> POST_BALL
    GOOD_RUNOUT --> POST_BALL
    GOOD_SAFE --> POST_BALL
    GOOD_A_IN_GAP --> POST_BALL
    GOOD_CAUGHT_EASY --> POST_BALL
    GOOD_DROP_EASY --> POST_BALL
    GOOD_CAUGHT_HARD --> POST_BALL
    GOOD_STOP_A --> POST_BALL
    GOOD_DROP_HARD --> POST_BALL
    SMASHED_G_IN_GAP --> POST_BALL
    SMASHED_CLEAN --> POST_BALL
    SMASHED_MISFIELD_G --> POST_BALL
    SMASHED_MISFIELD_C --> POST_BALL
    SMASHED_MISS_THROW --> POST_BALL
    SMASHED_RUNOUT --> POST_BALL
    SMASHED_SAFE --> POST_BALL
    SMASHED_A_IN_GAP --> POST_BALL
    SMASHED_CAUGHT_EASY --> POST_BALL
    SMASHED_DROP_EASY --> POST_BALL
    SMASHED_CAUGHT_HARD --> POST_BALL
    SMASHED_STOP_A --> POST_BALL
    SMASHED_DROP_HARD --> POST_BALL
    
    POST_BALL --> END_CHECK{Match Status}
    END_CHECK --> NEXT_BALL[Next Ball]
    END_CHECK --> INNINGS_BREAK[Innings Break]
    END_CHECK --> MATCH_COMPLETE[Match Complete]
    
    NEXT_BALL --> START
    INNINGS_BREAK --> START
    
    %% STYLING
    classDef wicketNode fill:#ff9999,stroke:#ff0000,stroke-width:2px
    classDef boundaryNode fill:#99ccff,stroke:#0066cc,stroke-width:2px
    classDef runsNode fill:#99ff99,stroke:#00ff00,stroke-width:2px
    classDef dotNode fill:#ffffe0,stroke:#cccc00,stroke-width:1px
    
    class BOWLED,LBW,HIT_WICKET,CAUGHT_KEEPER,CAUGHT_SLIP,MISHIT_CAUGHT_EASY,MISHIT_CAUGHT_HARD,GOOD_CAUGHT_EASY,GOOD_CAUGHT_HARD,SMASHED_CAUGHT_EASY,SMASHED_CAUGHT_HARD,MISHIT_RUNOUT,GOOD_RUNOUT,SMASHED_RUNOUT wicketNode
    class GOOD_FOUR_G,GOOD_A_IN_GAP,GOOD_DROP_HARD,SMASHED_G_IN_GAP,SMASHED_A_IN_GAP,SMASHED_MISFIELD_G,SMASHED_MISFIELD_C,SMASHED_DROP_HARD boundaryNode
    class MISHIT_G_RUNS,MISHIT_A_RUNS,GOOD_G_RUNS,MISHIT_SAFE,GOOD_SAFE,SMASHED_SAFE,KEEPER_FUMBLE,SLIP_DROP,EDGE_RUNS runsNode
    class BEATEN,MISHIT_CLEAN,GOOD_CLEAN,SMASHED_CLEAN dotNode
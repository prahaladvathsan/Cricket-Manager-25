{
    "version": "1.0",
    "description": "Skill activation triggers for Cricket Manager 25. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "match-engine-debugger": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Debug and trace the 7-stage match engine modifier chain",
            "promptTriggers": {
                "keywords": [
                    "match engine",
                    "ball simulation",
                    "modifier chain",
                    "playstyle modifier",
                    "attribute modifier",
                    "SimpleBallSimulator",
                    "TacticsModifierSystem",
                    "contact calculator",
                    "trajectory",
                    "fielding calculator",
                    "decision calculator",
                    "ball outcome"
                ],
                "intentPatterns": [
                    "(debug|fix|trace|investigate).*?(match|ball|modifier|playstyle|attribute)",
                    "(why|how).*?(ball|outcome|modifier|runs|wicket|boundary)",
                    "(match engine|ball sim).*?(bug|issue|problem|wrong)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src/core/match-engine/**/*.js",
                    "src/core/tactics/**/*.js",
                    "src/data/config/playstyle-*.json",
                    "src/data/config/tactics-config.json",
                    "src/data/config/bowling-plans-config.json"
                ]
            }
        },
        "dual-mode-validator": {
            "type": "domain",
            "enforcement": "warn",
            "priority": "critical",
            "description": "Validate Normal UI and Sim-to-Date mode produce identical outcomes",
            "promptTriggers": {
                "keywords": [
                    "game flow",
                    "handleContinue",
                    "simulateDay",
                    "sim-to-date",
                    "SimulationEngine",
                    "calendar event",
                    "advance day",
                    "continue button"
                ],
                "intentPatterns": [
                    "(modify|change|update|fix).*?(game flow|progression|continue|calendar|advance)",
                    "(add|create).*?(calendar event|game event|match day)",
                    "(Header|SimulationEngine).*?(change|update|modify)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src/components/layout/Header.jsx",
                    "src/core/simulation/SimulationEngine.js"
                ]
            }
        },
        "cricket-domain-context": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Cricket Manager 25 domain reference - attributes, playstyles, formulas, rules",
            "promptTriggers": {
                "keywords": [
                    "player attribute",
                    "playstyle rating",
                    "NRR",
                    "net run rate",
                    "auction formula",
                    "valuation",
                    "transfer listing",
                    "retention",
                    "salary cap",
                    "combined rating",
                    "quality tier"
                ],
                "intentPatterns": [
                    "(how|what|explain).*?(attribute|playstyle|rating|NRR|valuation|auction|transfer)",
                    "(calculate|compute|formula).*?(rating|value|price|NRR)"
                ]
            }
        },
        "react-tailwind-zustand-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "React/Tailwind/Zustand best practices for Cricket Manager 25",
            "promptTriggers": {
                "keywords": [
                    "component",
                    "react component",
                    "UI",
                    "interface",
                    "page",
                    "modal",
                    "dialog",
                    "form",
                    "styling",
                    "frontend",
                    "React",
                    "Tailwind",
                    "Zustand",
                    "store",
                    "state management"
                ],
                "intentPatterns": [
                    "(create|add|make|build|update|modify).*?(component|UI|page|modal|dialog|form)",
                    "(how to|best practice).*?(component|react|styling)",
                    "(style|design|layout).*?(component|UI)",
                    "(manage|update).*?state"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src/**/*.jsx",
                    "src/components/**/*.jsx",
                    "src/pages/**/*.jsx",
                    "src/stores/**/*.js"
                ],
                "pathExclusions": [
                    "**/*.test.jsx",
                    "**/*.test.js",
                    "**/*.spec.jsx"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "customization": {
            "pathPatterns": "Adjust to match your project structure (src/, components/, etc.)",
            "keywords": "Add domain-specific terms relevant to your project",
            "intentPatterns": "Use regex for flexible user intent matching"
        }
    }
}
